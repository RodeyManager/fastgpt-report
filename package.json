{
  "name": "fastgpt-report-monorepo",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter fastgpt-analysis-report dev",
    "dev:demo": "pnpm --filter knowledge-process-demo dev",
    "dev:ragflow": "pnpm --filter ragflow-report dev",
    "build": "pnpm --filter fastgpt-analysis-report build && pnpm --filter knowledge-process-demo build && pnpm --filter ragflow-report build",
    "build:report": "pnpm --filter fastgpt-analysis-report build",
    "build:demo": "pnpm --filter knowledge-process-demo build",
    "build:ragflow": "pnpm --filter ragflow-report build",
    "preview": "pnpm --filter fastgpt-analysis-report preview"
  }
}
